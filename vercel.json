{
  "version": 2,
  "outputDirectory": "artifacts/water-dashboard/dist/public",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/artifacts/api-server/src/vercel.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/artifacts/water-dashboard/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
